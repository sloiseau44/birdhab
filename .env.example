# Copier ce fichier en .env (non versionné) et changer les valeurs avant tout
# usage réel (exposé au-delà de ta machine). Sans .env, docker-compose.yml
# utilise les valeurs par défaut ci-dessous, adaptées uniquement à un essai
# local rapide.

# Secret de signature des JWT, partagé par tous les services — une fuite ou une
# valeur par défaut en production permet de forger des jetons valides pour
# n'importe quel compte.
JWT_SECRET=changeme-local-dev-secret-key-not-for-production-use-only

# Mot de passe PostgreSQL (utilisateur "birdhab")
POSTGRES_PASSWORD=birdhab

# Identifiants MinIO (stockage des documents d'identité)
MINIO_ROOT_PASSWORD=birdhab123

# Port HTTP exposé sur la machine hôte pour accéder à l'application
BIRDHAB_PORT=8888
